# =============================================================================
# travel-agent 环境变量配置模板
# 复制为 .env 后修改对应值即可
# cp .env.example .env
# =============================================================================

# =============================================================================
# 1. RAG 向量存储配置
# =============================================================================
TRAVEL_RAG_PERSIST_DIR=data/chroma
TRAVEL_RAG_COLLECTION_NAME=travel_destinations

# =============================================================================
# 2. Embedding 提供商配置
# =============================================================================
# auto:     优先 DASHSCOPE_API_KEY → 通义千问; 否则 OPENAI_API_KEY → OpenAI; 都无则 local
# qwen:     通义千问 text-embedding-v4 (需 DASHSCOPE_API_KEY)
# openai:   OpenAI embedding (需 OPENAI_API_KEY)
# sentence-transformers: 本地 BGE-M3 (需 pip install -e ".[local-embeddings]")
# local:    确定性 hash embedding, 仅用于 CI/demo, 不保证语义质量
TRAVEL_RAG_EMBEDDING_PROVIDER=auto

# 通义千问 Embedding
TRAVEL_RAG_QWEN_EMBEDDING_MODEL=text-embedding-v4
TRAVEL_RAG_QWEN_EMBEDDING_DIMENSIONS=1024
TRAVEL_RAG_QWEN_EMBEDDING_BATCH_SIZE=10
TRAVEL_RAG_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI Embedding
TRAVEL_RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 本地 Sentence-Transformers
TRAVEL_RAG_SENTENCE_TRANSFORMERS_MODEL=BAAI/bge-m3

# 本地 Hash Embedding (仅 demo)
TRAVEL_RAG_LOCAL_EMBEDDING_DIMENSIONS=512

# =============================================================================
# 3. 文本切片配置
# =============================================================================
TRAVEL_RAG_CHUNK_SIZE=800
TRAVEL_RAG_CHUNK_OVERLAP=120

# =============================================================================
# 4. 检索配置
# =============================================================================
# 检索模式: vector / keyword / hybrid (推荐)
TRAVEL_RAG_RETRIEVAL_MODE=hybrid

# 默认返回结果数
TRAVEL_RAG_DEFAULT_TOP_K=5

# 检索候选扩展倍数 (检索时会获取 top_k * candidate_multiplier 个候选)
TRAVEL_RAG_RETRIEVAL_CANDIDATE_MULTIPLIER=5

# 最低分数阈值 (0.0 表示不过滤)
TRAVEL_RAG_MIN_SCORE=0.0

# =============================================================================
# 5. 混合检索 RRF 融合配置
# =============================================================================
# RRF K 值 (越大越平滑, 默认 60)
TRAVEL_RAG_RRF_K=60
# 向量检索权重
TRAVEL_RAG_VECTOR_WEIGHT=1.0
# BM25 关键词检索权重
TRAVEL_RAG_KEYWORD_WEIGHT=1.0

# =============================================================================
# 6. 中文关键词检索配置
# =============================================================================
# 分词器: auto (优先 jieba) / jieba (强制) / builtin (内置词典)
TRAVEL_RAG_KEYWORD_TOKENIZER=auto
# 可选: jieba 自定义用户词典路径 (每行一个词)
TRAVEL_RAG_KEYWORD_USER_DICT=

# =============================================================================
# 7. Reranker 重排序配置
# =============================================================================
# keyword:        规则型 KeywordOverlapReranker (默认, 无模型依赖)
# bge-reranker:   BAAI/bge-reranker-base CrossEncoder (需 pip install -e ".[reranker]")
# cross-encoder:  CrossEncoder 通用配置 (可指定其他模型)
TRAVEL_RAG_RERANKER=keyword
TRAVEL_RAG_RERANKER_MODEL=BAAI/bge-reranker-base
TRAVEL_RAG_RERANKER_BATCH_SIZE=16
# 设备: cpu / cuda / 留空自动检测
TRAVEL_RAG_RERANKER_DEVICE=
# 模型加载/预测失败时是否回退到 keyword reranker
TRAVEL_RAG_RERANKER_FALLBACK=true

# =============================================================================
# 8. Agent LLM 配置
# =============================================================================
# LLM 提供商: qwen (通义千问) / openai
TRAVEL_AGENT_LLM_PROVIDER=qwen
# LLM 模型名称
TRAVEL_AGENT_MODEL=qwen3-max
# 可选: 自定义通义千问 Base URL
# TRAVEL_AGENT_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# 9. API Key 配置
# =============================================================================
# 阿里云百炼 API Key (用于通义千问 Embedding + LLM)
DASHSCOPE_API_KEY=

# OpenAI API Key (用于 OpenAI Embedding + LLM, 或作为 auto 的备选)
OPENAI_API_KEY=

# =============================================================================
# 10. LLMOps 可观测性配置 (可选, 不配置时自动 no-op)
# =============================================================================

# LangSmith (主 tracer)
# 设置后自动启用, 记录 user_request / evidence_count / confidence / planner / latency / plan 等
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_PROJECT=travel-agent

# Langfuse (可选 tracer, 与 LangSmith 并行)
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com
